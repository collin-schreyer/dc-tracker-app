# Data Center Lead Tracker - Environment Configuration

# Database Configuration
# For local development, SQLite works great (no setup needed)
DATABASE_URL=sqlite:///dc_tracker.db

# For production with PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/dc_tracker

# Redis (optional - for future background jobs)
REDIS_URL=redis://localhost:6379/0

# Flask Secret Key (change this for production!)
FLASK_SECRET_KEY=change-this-to-random-string-in-production

# Mapbox Token (not needed - we use free OpenStreetMap)
MAPBOX_TOKEN=not-needed
