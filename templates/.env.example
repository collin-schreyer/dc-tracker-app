# Database Configuration
DATABASE_URL=postgresql://user:password@localhost/datacenter_tracker

# Mapbox Token (for map visualization)
MAPBOX_TOKEN=your_mapbox_token_here

# Scraper Configuration
SCRAPER_DELAY=1  # Delay between requests in seconds
USER_AGENT=DataCenterTracker/1.0

# Redis Configuration (for Celery task queue)
REDIS_URL=redis://localhost:6379/0